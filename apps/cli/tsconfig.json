{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["node_modules", "test", "**/*.test.js", "**/*.test.jsx", "**/*.e2e.js"]
}
