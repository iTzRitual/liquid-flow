{
  "name": "liquid-flow",
  "version": "2.0.0",
  "description": "Liquid Flow — synchronizacja i hot-reload szablonów Liquid sklepów Comarch e-Sklep. Aplikacja desktopowa i CLI.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @liquidflow/desktop",
    "build": "npm run build --workspace @liquidflow/desktop",
    "build:mac": "npm run build:mac --workspace @liquidflow/desktop",
    "build:win": "npm run build:win --workspace @liquidflow/desktop",
    "build:linux": "npm run build:linux --workspace @liquidflow/desktop",
    "cli": "npm start --workspace @liquidflow/cli"
  },
  "engines": {
    "node": ">=18"
  }
}
