{
  "name": "liquid-flow",
  "version": "0.9.184",
  "description": "Liquid Flow — synchronizacja i hot-reload szablonów Liquid sklepów Comarch e-Sklep. Aplikacja desktopowa i CLI.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @liquidflow/desktop",
    "build": "npm run build --workspace @liquidflow/desktop",
    "build:mac": "npm run build:mac --workspace @liquidflow/desktop",
    "build:win": "npm run build:win --workspace @liquidflow/desktop",
    "build:linux": "npm run build:linux --workspace @liquidflow/desktop",
    "cli": "npm start --workspace @liquidflow/cli",
    "test": "vitest run && vitest run --config vitest.renderer.config.js",
    "test:renderer": "vitest run --config vitest.renderer.config.js",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "ink-testing-library": "^4.0.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
